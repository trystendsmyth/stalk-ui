{
  "name": "@stalk-ui/i18n",
  "version": "0.1.0",
  "description": "Internationalization utilities for Stalk UI - provider, Intl wrappers, locale messages.",
  "keywords": [
    "i18n",
    "react",
    "intl",
    "locale",
    "stalk-ui"
  ],
  "homepage": "https://stalk-ui.com",
  "bugs": "https://github.com/trystendsmyth/stalk-ui/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trystendsmyth/stalk-ui.git",
    "directory": "packages/i18n"
  },
  "license": "MIT",
  "author": "Tristan Smith trystendsmyth@gmail.com",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./locales/en": {
      "import": {
        "types": "./dist/locales/en.d.ts",
        "default": "./dist/locales/en.js"
      },
      "require": {
        "types": "./dist/locales/en.d.cts",
        "default": "./dist/locales/en.cjs"
      }
    },
    "./locales/*": {
      "import": {
        "types": "./dist/locales/*.d.ts",
        "default": "./dist/locales/*.js"
      },
      "require": {
        "types": "./dist/locales/*.d.cts",
        "default": "./dist/locales/*.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "locales/*": [
        "./dist/locales/*.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "prepack": "tsx ../../scripts/generate-i18n-exports.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "^29.0.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
