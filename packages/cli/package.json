{
  "name": "@stalk-ui/cli",
  "version": "0.0.0",
  "description": "CLI for installing and upgrading Stalk UI components",
  "keywords": [
    "cli",
    "components",
    "registry",
    "stalk-ui"
  ],
  "homepage": "https://stalk-ui.com",
  "bugs": "https://github.com/trystendsmyth/stalk-ui/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trystendsmyth/stalk-ui.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Tristan Smith trystendsmyth@gmail.com",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "bin": {
    "stalk-ui": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "ts-morph": "^28.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
