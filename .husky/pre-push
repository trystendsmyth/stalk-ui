branch="$(git branch --show-current)"

case "$branch" in
  main | release/* | changeset-release/* | dependabot/*)
    exit 0
    ;;
esac

if ! printf '%s\n' "$branch" | grep -Eq '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|a11y)/[a-z0-9][a-z0-9-]*$'; then
  echo "Branch name must match <type>/<kebab-description>."
  echo "Allowed types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert, a11y."
  exit 1
fi
