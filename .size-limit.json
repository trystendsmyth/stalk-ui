[
  {
    "name": "@stalk-ui/preset",
    "disablePlugins": ["@size-limit/esbuild", "@size-limit/webpack"],
    "path": "packages/preset/dist/index.js",
    "limit": "10 KB",
    "webpack": false
  },
  {
    "name": "@stalk-ui/i18n (main entry - provider + Intl wrappers)",
    "disablePlugins": ["@size-limit/esbuild", "@size-limit/webpack"],
    "path": "packages/i18n/dist/index.js",
    "limit": "4 KB",
    "webpack": false
  },
  {
    "name": "@stalk-ui/i18n/locales/en (single locale)",
    "disablePlugins": ["@size-limit/esbuild", "@size-limit/webpack"],
    "path": "packages/i18n/dist/locales/en.js",
    "limit": "2 KB",
    "webpack": false
  },
  {
    "name": "@stalk-ui/i18n tree-shake test (main + en only)",
    "path": ".size-limit-fixtures/i18n-en-only/dist/assets/*.js",
    "limit": "5 KB",
    "ignore": ["react", "react-dom"]
  },
  {
    "name": "@stalk-ui/cli",
    "disablePlugins": ["@size-limit/esbuild", "@size-limit/webpack"],
    "path": "packages/cli/dist/bin.js",
    "limit": "40 KB",
    "webpack": false
  }
]
