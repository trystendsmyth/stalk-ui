{
  "name": "stalk-ui",
  "version": "0.0.0",
  "private": true,
  "description": "A PandaCSS-native component library distributed through a first-party CLI, preset, and static registry manifests.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:registry": "tsx scripts/build-registry.ts",
    "changeset": "changeset",
    "changeset:publish": "turbo run build && changeset publish",
    "changeset:version": "changeset version",
    "check-docs": "tsx scripts/check-docs-drift.ts",
    "check-exports": "pnpm --filter @stalk-ui/cli build && pnpm --filter @stalk-ui/i18n build && pnpm --filter @stalk-ui/preset build && tsx scripts/check-exports.ts",
    "check-i18n-exports": "tsx scripts/check-i18n-exports-drift.ts",
    "check-registry": "tsx scripts/check-registry-drift.ts",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write . --cache",
    "format:check": "prettier --check . --cache",
    "generate-docs": "tsx scripts/generate-docs.ts",
    "lint": "eslint . --cache && tsx scripts/check-package-contracts.ts && turbo run lint",
    "lost-pixel": "pnpm --filter @stalk-ui/storybook build && lost-pixel",
    "prepare": "husky",
    "registry:serve": "tsx scripts/serve-registry.ts",
    "registry:watch": "tsx scripts/watch-registry.ts",
    "size": "pnpm --filter @stalk-ui/i18n build && tsup .size-limit-fixtures/i18n-en-only/src/main.ts --format esm --out-dir .size-limit-fixtures/i18n-en-only/dist/assets --minify --splitting false --external react --external react-dom && size-limit",
    "syncpack:check": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "test": "turbo run test",
    "test:a11y:docs": "tsx scripts/test-docs-a11y.ts",
    "test:a11y:storybook": "tsx scripts/test-storybook-a11y.ts",
    "test:integration:next": "tsx scripts/test-integration-fixture.ts next",
    "test:integration:shadcn": "tsx scripts/test-integration-fixture.ts shadcn",
    "test:integration:vite": "tsx scripts/test-integration-fixture.ts vite",
    "test:publish": "tsx scripts/test-publish.ts",
    "test:shadcn-compat": "tsx scripts/test-shadcn-compat.ts",
    "typecheck": "turbo run typecheck",
    "verdaccio:publish": "tsx scripts/verdaccio-publish.ts",
    "verdaccio:start": "pnpm dlx verdaccio --config .verdaccio/config.yaml",
    "verify-preset": "tsx scripts/verify-preset.ts",
    "verify-tree-shaking": "tsx scripts/verify-tree-shaking.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --cache --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ],
    "package.json": [
      "prettier --write --plugin prettier-plugin-packagejson"
    ]
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@changesets/release-utils": "^0.2.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9",
    "@next/eslint-plugin-next": "15",
    "@pandacss/dev": "catalog:",
    "@pandacss/preset-base": "1.9.1",
    "@size-limit/file": "^12.1.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@size-limit/webpack": "^12.1.0",
    "@types/node": "^24.12.2",
    "chokidar": "^5.0.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lost-pixel": "^3.22.0",
    "pa11y-ci": "^4.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "publint": "^0.3.18",
    "puppeteer": "^24.42.0",
    "size-limit": "^12.1.0",
    "syncpack": "^14.3.0",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "typescript-eslint": "^8.59.0",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
