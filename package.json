{
  "name": "stalk-ui",
  "version": "0.0.0",
  "private": true,
  "description": "A PandaCSS-native component library distributed through a first-party CLI, preset, and static registry manifests.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write . --cache",
    "format:check": "prettier --check . --cache",
    "lint": "eslint . --cache",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
