{
  "name": "@stalk-ui/storybook",
  "version": "0.0.0",
  "private": true,
  "description": "Storybook workspace for Stalk UI.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "pnpm run codegen",
    "build": "storybook build --output-dir storybook-static",
    "clean": "rimraf storybook-static styled-system .lost-pixel/current .lost-pixel/difference",
    "codegen": "pnpm --filter @stalk-ui/i18n build && pnpm --filter @stalk-ui/preset build && panda codegen && panda cssgen",
    "predev": "pnpm run codegen",
    "dev": "storybook dev --port 6006",
    "lint": "eslint .",
    "test": "pnpm --workspace-root check-storybook-coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans": "^5.2.5",
    "@stalk-ui/i18n": "workspace:^",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@pandacss/dev": "catalog:",
    "@stalk-ui/preset": "workspace:*",
    "@storybook-community/storybook-dark-mode": "^7.1.2",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "storybook": "catalog:",
    "vite": "^8.0.10"
  }
}
