{
  "name": "@stalk-ui/storybook",
  "version": "0.0.0",
  "private": true,
  "description": "Storybook workspace for Stalk UI.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @stalk-ui/preset build && panda codegen && panda cssgen",
    "build": "storybook build --output-dir storybook-static",
    "predev": "pnpm --filter @stalk-ui/preset build && panda codegen && panda cssgen",
    "dev": "storybook dev --port 6006",
    "lint": "echo \"No Storybook lint configured yet\"",
    "test": "echo \"No Storybook tests configured yet\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@pandacss/dev": "catalog:",
    "@pandacss/preset-base": "1.9.1",
    "@stalk-ui/preset": "workspace:*",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "storybook": "catalog:",
    "vite": "^8.0.10"
  }
}
