{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stalk-ui.dev/schema/v1/registry-item.json",
  "type": "object",
  "required": ["$schema", "name", "type", "dependencies", "registryDependencies", "files", "stalk"],
  "properties": {
    "$schema": {
      "const": "https://stalk-ui.dev/schema/v1/registry-item.json"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "enum": ["registry:ui", "registry:lib", "registry:hook"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "registryDependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "type", "content"],
        "properties": {
          "path": {
            "type": "string"
          },
          "type": {
            "enum": ["registry:ui", "registry:lib", "registry:hook"]
          },
          "content": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "stalk": {
      "type": "object",
      "required": [
        "schemaVersion",
        "preset",
        "packageDependencies",
        "pandaCodegen",
        "importAliases"
      ],
      "properties": {
        "schemaVersion": {
          "const": "1.0"
        },
        "preset": {
          "type": "object",
          "required": ["semanticTokens", "recipes"],
          "properties": {
            "semanticTokens": {
              "type": "object"
            },
            "recipes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "packageDependencies": {
          "type": "object",
          "required": ["preset"],
          "properties": {
            "preset": {
              "const": "@stalk-ui/preset"
            },
            "i18n": {
              "const": "@stalk-ui/i18n"
            }
          },
          "additionalProperties": false
        },
        "pandaCodegen": {
          "type": "boolean"
        },
        "importAliases": {
          "type": "object",
          "required": ["styledSystem"],
          "properties": {
            "styledSystem": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
